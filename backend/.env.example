# Backend Configuration
DEBUG=false
HOST=0.0.0.0
PORT=8000

# API Configuration
API_TITLE="AI News Intelligence Platform"
API_VERSION="1.0.0"
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Supabase Configuration
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo

# Relay.app Configuration
RELAY_WEBHOOK_URL=your_relay_webhook_url
RELAY_API_KEY=your_relay_api_key

# Email Configuration (SMTP Fallback)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
FROM_EMAIL=your_email@gmail.com

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/news_platform

# ML Configuration
TF_IDF_MAX_FEATURES=5000
SIMILARITY_THRESHOLD=0.3
